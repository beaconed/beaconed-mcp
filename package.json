{
  "name": "@beaconed/mcp",
  "version": "0.0.1",
  "description": "MCP server for the Beaconed v1 API",
  "keywords": ["beaconed", "mcp", "model-context-protocol", "claude", "ai", "ecommerce", "shopify", "seo"],
  "author": "Beaconed, Inc.",
  "license": "MIT",
  "homepage": "https://github.com/beaconed/beaconed-mcp#readme",
  "repository": { "type": "git", "url": "git+https://github.com/beaconed/beaconed-mcp.git" },
  "bugs": { "url": "https://github.com/beaconed/beaconed-mcp/issues" },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "beaconed-mcp": "./dist/server.js"
  },
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "dev": "tsx src/server.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@beaconed/api-client": "file:../beaconed-api-client",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "8.18.2",
    "@typescript-eslint/parser": "8.18.2",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
